{
  "name": "sekondbrain-kanvas",
  "version": "2.4.0",
  "description": "Kanvas for Kit - AI Agent Dashboard",
  "main": "dist/electron/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "CXXFLAGS='-std=c++20' electron-builder install-app-deps",
    "cli": "./start-devops-session.sh",
    "cli:list": "node src/session-coordinator.js list",
    "cli:start": "node src/session-coordinator.js start",
    "cli:close": "node src/close-session.js",
    "cli:cleanup": "./cleanup-sessions.sh",
    "test": "jest",
    "test:kanvas": "jest --config jest.kanvas.config.cjs",
    "test:mcp": "jest --config jest.kanvas.config.cjs --testPathPattern='(Mcp|McpAgent)'",
    "test:multi-repo": "jest --config jest.kanvas.config.cjs --testPathPattern='MultiRepo'",
    "test:contracts": "jest tests/unit/generate-contracts.test.js tests/integration/contract-workflow.test.js",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx",
    "check:loc": "node scripts/check-file-loc.js --all",
    "check:loc:staged": "node scripts/check-file-loc.js",
    "check:loc:report": "node scripts/check-file-loc.js --all --report"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^3.5.3",
    "detect-port": "^2.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.7.3",
    "glob": "^13.0.6",
    "groq-sdk": "^1.1.2",
    "js-yaml": "^4.1.0",
    "openai": "^6.33.0",
    "react-markdown": "^10.1.0",
    "react-window": "^1.8.11",
    "remark-gfm": "^4.0.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.sekondbrain.kanvas",
    "productName": "Kanvas for Kit",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "overrides": {
    "rimraf": "^6.1.3",
    "tar": "^7.1.0",
    "test-exclude": "^8.0.0",
    "@electron/asar": "^4.2.0",
    "cacache": "^20.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "SeKondBrain AI Labs <dev@sekondbrain.com>",
  "license": "MIT"
}
